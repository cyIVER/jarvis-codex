{
  "appId": "local.jarvis.codex.hud",
  "productName": "Jarvis Codex",
  "asar": true,
  "npmRebuild": false,
  "directories": {
    "buildResources": "assets",
    "output": "dist"
  },
  "icon": "icon.png",
  "files": [
    "main.js",
    "preload.js",
    "package.json"
  ],
  "linux": {
    "target": [
      "AppImage"
    ],
    "category": "Development",
    "syncDesktopName": true
  },
  "mac": {
    "target": [
      "dmg"
    ],
    "category": "public.app-category.developer-tools"
  },
  "win": {
    "target": [
      "portable"
    ],
    "artifactName": "Jarvis Codex-${version}-portable.${ext}"
  }
}
