{
  "name": "jarvis-codex-electron-hud",
  "version": "0.1.0",
  "private": true,
  "description": "Local-only Electron shell for the Jarvis Codex runtime HUD.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --dir --config electron-builder.json",
    "make": "electron-builder --config electron-builder.json --publish never"
  },
  "devDependencies": {
    "electron": "42.4.1",
    "electron-builder": "26.15.3"
  }
}
