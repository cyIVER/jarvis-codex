filters:
  and:
    - 'file.inFolder("docs/jarvis-harness/vault")'
    - 'file.hasTag("decisions")'
properties:
  status:
    displayName: "Status"
  file.mtime:
    displayName: "Modified"
views:
  - type: table
    name: "Decision Notes"
    order:
      - file.name
      - status
      - file.mtime

