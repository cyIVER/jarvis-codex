{
  "name": "@jarvis-codex/remotion-review-assets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts JarvisCodexPlan out/jarvis-codex-plan.mp4",
    "render:gpu": "remotion render src/index.ts JarvisCodexPlan out/jarvis-codex-plan.mp4 --gl=angle --chrome-mode=chrome-for-testing",
    "still": "remotion still src/index.ts JarvisCodexPlan out/jarvis-codex-plan.png --frame=120",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.481",
    "remotion": "4.0.481",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "typescript": "5.5.4"
  }
}
